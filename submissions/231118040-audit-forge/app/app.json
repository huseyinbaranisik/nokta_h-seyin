    "android": {
      "package": "com.nokta.auditforge",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0f172a"
      }
    },
    "ios": {
      "bundleIdentifier": "com.nokta.auditforge"
    },
    "plugins": [
      "expo-router"
    ]
  }
}
